{
  "name": "sociotype-test",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "animejs": "^2.2.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^5.3.11"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,json,css}": [
      "prettier --single-quote --write",
      "git add"
    ]
  },
  "scripts": {
    "precommit": "lint-staged",
    "start": "vite --host 0.0.0.0",
    "build": "vite build",
    "test": "vitest run",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "homepage": "https://Erscheinung.github.io/sociotype-test/",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "gh-pages": "^6.1.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
